# ════════════════════════════════════════════════════════════
#  AI 小说工厂 — 环境变量模板
#  复制此文件为 .env，按需填写后再运行 docker-compose up -d
# ════════════════════════════════════════════════════════════

# ── 应用基础 ──────────────────────────────────────────────
APP_NAME=StorySmith
DEBUG=false

# 前端监听端口（默认 3000，访问地址：http://localhost:3000）
FRONTEND_PORT=3000

# ── LLM（必填）────────────────────────────────────────────
# 支持 OpenAI 兼容接口，可接入 Azure / 代理 / Qwen 等
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 意图分类模型（可与上方相同）
INTENT_MODEL=gpt-4o-mini

# ── 小说生成专用 LLM（可选，留空则回退到上方 OPENAI_* 配置）──
NOVEL_OPENAI_API_KEY=
NOVEL_OPENAI_BASE_URL=
NOVEL_OPENAI_MODEL=gpt-4o

# ── Agent 模式 ────────────────────────────────────────────
# router   → 意图路由（推荐）
# dify     → Dify 远程工作流
# general  → 通用 Agent
AGENT_MODE=router

# ── Dify（仅 AGENT_MODE=dify 时有效）────────────────────
DIFY_API_URL=
DIFY_API_KEY=

# ── 对话记忆 / Checkpoint ─────────────────────────────────
# none     → 无记忆
# memory   → 内存（重启丢失）
# sqlite   → SQLite 持久化（默认，推荐）
# postgres → PostgreSQL 持久化
CHECKPOINT_BACKEND=sqlite
CHECKPOINT_SQLITE_PATH=./memory/checkpoints.db

# ── PostgreSQL（可选，留空则使用 SQLite 存储小说数据）──────
PG_HOST=
PG_PORT=5432
PG_USER=
PG_PASSWORD=
PG_DATABASE=ai_novel
PG_POOL_MIN=2
PG_POOL_MAX=10

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ── WebSocket ────────────────────────────────────────────
# 连接空闲超时秒数，0 表示不超时
WS_IDLE_TIMEOUT=3600

# ── Novel Agent 工作空间（容器内路径）────────────────────
# 如果项目使用 create_openclaw_style_agent_norm.py，需指定项目根路径
# 容器内固定为 /app，通常无需修改
NOVEL_PROJECT_ROOT=/app
